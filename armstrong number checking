#include <stdio.h>
#include <math.h>
int main() {
    int n, s = 0, c = 0, r, original;
    printf("Enter the number:");
    scanf("%d", &n);

    original = n;
    while (n > 0) {
        c = c + 1;
        n = n / 10;
    }

    n = original;
    while (n > 0) {
        r = n % 10;
        s = s + pow(r, c);
        n = n / 10;
    }

    if (s == original) {
        printf("%d is armstrong number", original);
    } else {
        printf("%d is not armstrong number", original);
    }
    return 0;
}
