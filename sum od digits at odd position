#include <stdio.h>
int main() {
    int n, r, original, s = 0, i = 0;
    printf("Enter the number:");
    scanf("%d", &n);

    original = n;
    while (n > 0) {
        r = n % 10;
        i++;
        if (i % 2 != 0) {
            s = s + r;
        }
        n = n / 10;
    }
    printf("\nSum of odd position = %d", s);
    return 0;
}
