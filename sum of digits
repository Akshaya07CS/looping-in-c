#include <stdio.h>
int main() {
    int n, s = 0, r, original;
    printf("Enter the number:");
    scanf("%d", &n);

    original = n;
    while (n > 0) {
        r = n % 10;
        printf("%d", r);
        s = s + r;
        n = n / 10;
    }
    printf("\nSum of digits of %d is %d\n", original, s);
    printf("Finished\n");
    return 0;
}
