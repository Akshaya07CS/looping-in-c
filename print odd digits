#include <stdio.h>
int main() {
    int n, r, original;
    printf("Enter the number:");
    scanf("%d", &n);

    original = n;
    printf("Odd digits in %d are :", original);

    while (n > 0) {
        r = n % 10;
        if (r % 2 != 0) {
            printf("%d", r);
        }
        n = n / 10;
    }
    printf("\nFinished");
    return 0;
}
